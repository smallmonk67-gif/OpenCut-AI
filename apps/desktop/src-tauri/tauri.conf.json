{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktop",
  "version": "0.1.0",
  "identifier": "com.yitteng.desktop",
  "build": {
    "beforeDevCommand": "bun --filter=@opencut/web run dev",
    "beforeBuildCommand": "bun --filter=@opencut/web run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist/client"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "desktop",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
